{
  "name": "kairo-quest-bot",
  "version": "0.1.0",
  "description": "Pure-API multi-account auto-swap + daily quest bot for Kairo DEX",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "tsx src/main.ts",
    "run:once": "tsx src/main.ts --once",
    "check": "tsx src/main.ts --check",
    "quests": "tsx src/main.ts --quests",
    "schedule": "tsx src/main.ts --schedule",
    "telegram": "tsx src/main.ts --telegram",
    "add-account": "tsx tools/add-account.ts",
    "receiver": "tsx tools/receiver.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "crypto-js": "^4.2.0",
    "js-yaml": "^4.1.0",
    "node-cron": "^4.2.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.60.0",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.2",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
